<?xml version="1.0" ?>

<robot name="payload_box">

  <properties l="0.4"/>

  <link name="baseLink">

    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.04"/>
      <inertia ixx="0.000625" ixy="0" ixz="0"
               iyy="0.000625" iyz="0"
               izz="0.000625"/>
    </inertial>

    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.4 0.4 0.2"/>
      </geometry>
    </visual>

    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.4 0.4 0.2"/>
      </geometry>
    </collision>

  </link>

</robot>